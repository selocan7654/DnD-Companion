# ── Database ──
DATABASE_URL="postgresql://dnd_user:dnd_local_pass@localhost:5432/dnd_companion?schema=public"

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── JWT ──
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── SMTP (Gmail App Password) ──
# Development options:
#   1) Stub mode — leave SMTP_USER and SMTP_PASS empty; verification links are logged to the API console.
#   2) Real Gmail — set your address + App Password (https://myaccount.google.com/apppasswords).
#      SMTP_PORT=587 with STARTTLS is the default for Gmail.
# Do NOT keep the placeholder values below — SMTP will fail and no email is sent.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Object Storage (S3-compatible) ──
# Used by POST /uploads/presign — MinIO, Cloudflare R2, or AWS S3.
# S3_PUBLIC_URL is the CDN or public bucket URL returned to clients after upload.
S3_ENDPOINT="https://your-s3-endpoint"
S3_BUCKET="dnd-companion-uploads"
S3_REGION="auto"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_PUBLIC_URL="https://your-cdn-or-public-url"

# ── Application ──
APP_URL="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"
API_PORT=3000
NODE_ENV="development"

# Optional — Socket.io override when API is not same-origin (Vite proxies /socket.io by default)
# VITE_API_WS_URL="http://localhost:3000"

# ── Seed ──
SEED_ADMIN_EMAIL="admin@gmail.com"
SEED_ADMIN_PASSWORD="admin123"

# Development-only verified USER accounts (ignored when NODE_ENV=production)
SEED_TEST_USERS="true"
SEED_TEST_USER_PASSWORD="password123"

# ── Sentry (optional — leave empty in development) ──
SENTRY_DSN=""
