```typescript
// ✓ Doğru — tek modül, policy ayrık
// campaigns/campaigns.service.ts — iş mantığı
// common/policies/campaign.policy.ts — canUpdate()

// ✗ Yanlış — controller içinde 40 satır yetki if'i
@Patch(':id')
async update(@CurrentUser() user, @Param('id') id: string) {
  const c = await this.prisma.campaign.findUnique({ where: { id } });
  if (c.ownerId !== user.id && user.role !== 'ADMIN') throw new ForbiddenException();
  // ...
}
```

